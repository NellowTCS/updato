{
  "name": "@nellowtcs/updato",
  "version": "1.0.3",
  "type": "module",
  "description": "Updato client library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NellowTCS/updato.git"
  },
  "main": "dist/updato.cjs",
  "module": "dist/updato.mjs",
  "types": "dist/updato.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/updato.d.mts",
        "default": "./dist/updato.mjs"
      },
      "require": {
        "types": "./dist/updato.d.cts",
        "default": "./dist/updato.cjs"
      }
    },
    "./update-ui": {
      "import": {
        "types": "./dist/update-ui.d.mts",
        "default": "./dist/update-ui.mjs"
      },
      "require": {
        "types": "./dist/update-ui.d.cts",
        "default": "./dist/update-ui.cjs"
      }
    },
    "./metrics": {
      "import": {
        "types": "./dist/metrics.d.mts",
        "default": "./dist/metrics.mjs"
      },
      "require": {
        "types": "./dist/metrics.d.cts",
        "default": "./dist/metrics.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "make-pretty": "prettier --write .",
    "lint": "eslint . --ext .ts,.js --fix",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "tsdown": "^0.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "unrun": "^0.3.1"
  }
}
